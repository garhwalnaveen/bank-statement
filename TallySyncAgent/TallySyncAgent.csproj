<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>TallySyncAgent</RootNamespace>
    <AssemblyName>TallySyncAgent</AssemblyName>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationIcon>Resources\icon.ico</ApplicationIcon>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
  </PropertyGroup>

  <ItemGroup>
    <!-- TallyConnector - the core bridge to Tally Desktop -->
    <PackageReference Include="TallyConnector" Version="3.*" />
    <!-- Secure Windows credential storage -->
    <PackageReference Include="Microsoft.Windows.SDK.Win32Metadata" Version="53.0.1-preview" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Resources\icon.ico" Condition="Exists('Resources\icon.ico')" />
  </ItemGroup>

</Project>
